@Kuva.Email.Service_HostAddress = http://localhost:8080

POST {{Kuva.Email.Service_HostAddress}}/api/v1/emails/send
Content-Type: application/json

{
  "templateCode": "ORDER_RECEIVED",
  "externalReference": "order-123",
  "source": "Kuva.Orders",
  "priority": "Normal",
  "recipients": [
    {
      "email": "cliente@email.com",
      "name": "Cliente Kuva",
      "type": "To"
    }
  ],
  "variables": {
    "customerName": "Cliente Kuva",
    "orderNumber": "123",
    "storeName": "Loja Piloto"
  },
  "metadata": {
    "orderId": "123",
    "storeId": "456"
  }
}

